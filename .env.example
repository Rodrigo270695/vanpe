APP_NAME=VanPe
VITE_APP_NAME="${APP_NAME}"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://vanpe.pe

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Google Sign-In de la app turista (Android/iOS/Web Client IDs, CSV).
# Separado del OAuth web de owners/plataforma.
TOURIST_GOOGLE_CLIENT_IDS=

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Base origen VetSaaS (para importar el catálogo geográfico)
# VETSAAS_DB_HOST=127.0.0.1
# VETSAAS_DB_PORT=5432
# VETSAAS_DB_DATABASE=vetsaas
# VETSAAS_DB_USERNAME=postgres
# VETSAAS_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Multi-tenancy por subdominio ──
# Hosts centrales que NO representan restaurantes.
TENANT_CENTRAL_DOMAINS="vanpe.pe,www.vanpe.pe"
# Sufijo oficial: elcantaro.vanpe.pe → elcantaro
TENANT_ROOT_DOMAIN=vanpe.pe
TENANT_SCHEME=https
# Prefijo obligatorio del schema (coincide con TenantProvisioner)
TENANT_SCHEMA_PREFIX=rst_
# Cache de resolución tenant→schema (0 en dev; 60–300 en prod)
TENANT_CACHE_TTL=0

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_VERIFY_PEER=true
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Web Push (PWA) — genera con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
